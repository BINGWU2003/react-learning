---
import { Code, TabItem, Tabs } from "@astrojs/starlight/components";

type SourceFile = {
  code: string;
  fileName: string;
  language: string;
};

type Props = {
  framework: "React" | "Vue 3";
  summary: string;
  tone: "react" | "vue";
  sources: SourceFile[];
};

const { framework, summary, tone, sources } = Astro.props;
const hasMultipleSources = sources.length > 1;
const hasFlow = Astro.slots.has("flow");
---

<article class:list={["framework-card", `framework-card--${tone}`]}>
  <header class="framework-card__header">
    <div>
      <span class="framework-card__dot" aria-hidden="true"></span>
      <strong>{framework}</strong>
    </div>
    <p>{summary}</p>
  </header>

  <div class="framework-card__preview">
    <p class="framework-card__eyebrow">在线预览</p>
    <slot />
  </div>

  {
    hasFlow && (
      <div class="framework-card__flow">
        <slot name="flow" />
      </div>
    )
  }

  <div class="framework-card__source" aria-label={`${framework} 源代码`}>
    <p class="framework-card__eyebrow">实际运行源码</p>
    <div
      class:list={[
        "framework-card__code-list",
        { "framework-card__code-list--tabs": hasMultipleSources },
      ]}
    >
      {
        hasMultipleSources ? (
          <Tabs>
            {sources.map(({ code, fileName, language }) => (
              <TabItem label={fileName}>
                <Code code={code.trim()} lang={language} />
              </TabItem>
            ))}
          </Tabs>
        ) : (
          sources.map(({ code, fileName, language }) => (
            <Code
              code={code.trim()}
              lang={language}
              meta={`title="${fileName}"`}
            />
          ))
        )
      }
    </div>
  </div>
</article>
